{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    // "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@homeos/schemas": ["../schemas/src/index.ts"],
      "@homeos/backend": ["../backend/src/index.ts"],
      "@homeos/backend/*": ["../backend/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
